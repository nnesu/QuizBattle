<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="QuizBattle.SignUpPage">

    <VerticalStackLayout
        Padding="30"
        Spacing="15">

        <Entry
            x:Name="EmailEntry"
            Placeholder="Email" />

        <!-- Password Field -->
        <Grid ColumnDefinitions="*, Auto">
            <Entry
                Grid.Column="0"
                x:Name="PasswordEntry"
                Placeholder="Password"
                IsPassword="True" />
            <Button
                Grid.Column="1"
                x:Name="TogglePasswordBtn"
                Text="👁️"
                WidthRequest="45"
                Padding="0"
                BackgroundColor="Transparent"
                TextColor="Gray"
                Clicked="TogglePassword_Clicked" />
        </Grid>

        <!-- Confirm Password Field -->
        <Grid ColumnDefinitions="*, Auto">
            <Entry
                Grid.Column="0"
                x:Name="ConfirmPasswordEntry"
                Placeholder="Confirm Password"
                IsPassword="True" />
            <Button
                Grid.Column="1"
                x:Name="ToggleConfirmPasswordBtn"
                Text="👁️"
                WidthRequest="45"
                Padding="0"
                BackgroundColor="Transparent"
                TextColor="Gray"
                Clicked="ToggleConfirmPassword_Clicked" />
        </Grid>

        <Button
            Text="Create Account"
            Clicked="Create_Clicked" />

        <Button
            Text="Already have an account?"
            Clicked="Login_Clicked" />

    </VerticalStackLayout>
</ContentPage>