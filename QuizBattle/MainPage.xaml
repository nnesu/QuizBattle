<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="QuizBattle.MainPage"
    Title="QUIZ BATTLE"
    BackgroundColor="#121212">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">

            <Button
                Text="GIVE UP / BACK"
                Clicked="OnGiveUpClicked"
                BackgroundColor="#E63946"
                TextColor="White"
                FontAttributes="Bold"
                HorizontalOptions="Start"
                HeightRequest="40"
                Padding="15,0"/>

            <Label
                x:Name="BossLabel"
                FontSize="22"
                TextColor="White"
                FontAttributes="Bold"
                HorizontalOptions="Center"/>

            <Label
                x:Name="LivesLabel"
                FontSize="22"
                TextColor="White"
                HorizontalOptions="Center"/>

            <HorizontalStackLayout
                x:Name="LivesLayout"
                IsVisible="False"
                HorizontalOptions="Center"
                Spacing="4"/>

            <Label
                x:Name="MasteryLabel"
                Text="Mastery: 0 / 1"
                FontSize="18"
                TextColor="LightGray"
                HorizontalOptions="Center"/>

            <Label
                x:Name="TimeLabel"
                Text="Time: --"
                FontSize="18"
                TextColor="#E9C46A"
                HorizontalOptions="Center"/>

            <BoxView HeightRequest="1" Color="#333" Margin="0,10"/>

            <Label
                x:Name="QuestionLabel"
                FontSize="20"
                TextColor="White"
                FontAttributes="Bold"
                HorizontalOptions="Center"/>

            <Entry
                x:Name="AnswerEntry"
                Placeholder="Type your answer"
                TextColor="White"
                PlaceholderColor="Gray"
                BackgroundColor="#222"/>

            <VerticalStackLayout
                x:Name="MultipleChoiceLayout"
                IsVisible="False"
                Spacing="10">

                <Button
                    x:Name="OptionButton1"
                    Clicked="OptionClicked"
                    BackgroundColor="LightGray"
                    TextColor="Black"
                    FontAttributes="Bold"/>

                <Button
                    x:Name="OptionButton2"
                    Clicked="OptionClicked"
                    BackgroundColor="LightGray"
                    TextColor="Black"
                    FontAttributes="Bold"/>

                <Button
                    x:Name="OptionButton3"
                    Clicked="OptionClicked"
                    BackgroundColor="LightGray"
                    TextColor="Black"
                    FontAttributes="Bold"/>

                <Button
                    x:Name="OptionButton4"
                    Clicked="OptionClicked"
                    BackgroundColor="LightGray"
                    TextColor="Black"
                    FontAttributes="Bold"/>

            </VerticalStackLayout>

            <Button
                Text="SUBMIT"
                Clicked="SubmitAnswer"
                BackgroundColor="#2A9D8F"
                TextColor="White"
                FontAttributes="Bold"
                HeightRequest="50"
                Margin="0,10,0,0"/>

            <Label
                x:Name="ResultLabel"
                FontSize="18"
                FontAttributes="Bold"
                HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>