<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizBattle.SourceMaterial"
             Title="GAME SETUP CONFIGURATIONS"
             BackgroundColor="#121212">

    <Grid>
        <ScrollView Padding="25">
            <VerticalStackLayout Spacing="18">

                <Label Text="SELECT GAME DIFFICULTY:" TextColor="White" FontAttributes="Bold" FontSize="14"/>

                <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="5">
                        <CheckBox x:Name="EasyCheck" IsChecked="False" Color="#2A9D8F" CheckedChanged="OnDifficultyChanged"/>
                        <Label Text="Easy" TextColor="White" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="5">
                        <CheckBox x:Name="NormalCheck" IsChecked="True" Color="#E9C46A" CheckedChanged="OnDifficultyChanged"/>
                        <Label Text="Normal" TextColor="White" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="5">
                        <CheckBox x:Name="HardCheck" IsChecked="False" Color="#E76F51" CheckedChanged="OnDifficultyChanged"/>
                        <Label Text="Hard" TextColor="White" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </HorizontalStackLayout>

                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10" VerticalOptions="Center" Margin="0,5">
                    <Label x:Name="TimerTitleLabel" 
                           Text="Timer (0-100s, Default: 15s):" 
                           TextColor="White" 
                           FontAttributes="Bold" 
                           VerticalOptions="Center" 
                           FontSize="14"/>

                    <Entry x:Name="TimerEntry" 
                           Grid.Column="1" 
                           Text="15" 
                           Keyboard="Numeric" 
                           TextColor="White" 
                           BackgroundColor="#222" 
                           HorizontalTextAlignment="Center" 
                           TextChanged="OnTimerTextChanged"/>
                </Grid>

                <BoxView HeightRequest="1" Color="#333" Margin="0,10"/>

                <Button Text="GENERATE NEW DECK" Clicked="OpenGenerateDeckModal" BackgroundColor="#2A9D8F" TextColor="White" HeightRequest="50" FontAttributes="Bold"/>

                <VerticalStackLayout Spacing="5">
                    <Label Text="Active Collection Selection:" TextColor="Gray" FontSize="12"/>
                    <Button x:Name="DeckDropdownButton" Text="CHOOSE DECK ▾" Clicked="ToggleDropdownLayout" BackgroundColor="#264653" HeightRequest="50" FontAttributes="Bold"/>

                    <ScrollView x:Name="DropdownScrollContainer" HeightRequest="150" BackgroundColor="#1A1A1A" IsVisible="False">
                        <VerticalStackLayout x:Name="DropdownStackList" Padding="5" Spacing="2"/>
                    </ScrollView>
                </VerticalStackLayout>

                <Button Text="IMPORT RAW DECK FILE" Clicked="OpenImportDeckModal" BackgroundColor="#457B9D" TextColor="White" HeightRequest="50" FontAttributes="Bold"/>

                <Button x:Name="LaunchGameButton" Text="LAUNCH BATTLE MATCH" Clicked="OnFinalLaunchClicked" 
                        BackgroundColor="#E76F51" TextColor="White" FontAttributes="Bold" HeightRequest="60" Margin="0,20,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="SetupPopupOverlay" BackgroundColor="#C0000000" IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="CloseSetupPopup"/>
            </Grid.GestureRecognizers>
            <Border BackgroundColor="#1F1F1F" Stroke="#444" WidthRequest="340" HorizontalOptions="Center" VerticalOptions="Center" Padding="20">
                <VerticalStackLayout x:Name="SetupPopupBody" Spacing="15"/>
            </Border>
        </Grid>
    </Grid>
</ContentPage>