<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizBattle.MainMenu"
             Title="Quiz Battle"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0A1020">
    <Grid Padding="24,22,24,20" RowDefinitions="Auto,*,Auto">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A1020" Offset="0" />
                <GradientStop Color="#12113A" Offset="0.58" />
                <GradientStop Color="#0B1B35" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- App mark and profile affordance -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
            <Border WidthRequest="44" HeightRequest="44" BackgroundColor="#8B5CF6" StrokeThickness="0" StrokeShape="RoundRectangle 14">
                <Label Text="QB" TextColor="White" FontSize="15" FontAttributes="Bold"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <Label Grid.Column="1" Text="QUIZ BATTLE" Margin="12,0,0,0" TextColor="#F8FAFC"
                   FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />

            <!-- Top Right Profile Button -->
            <Border Grid.Column="2" WidthRequest="42" HeightRequest="42" BackgroundColor="#18213C"
                    Stroke="#31405F" StrokeThickness="1" StrokeShape="RoundRectangle 21">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAccountSettingsClicked" />
                </Border.GestureRecognizers>
                <Image x:Name="ProfileImage" Source="avatar1.png" Aspect="AspectFill"
                       WidthRequest="42" HeightRequest="42" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- Hero -->
        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" Spacing="0" MaximumWidthRequest="560">
            <Border HeightRequest="34" BackgroundColor="#221D4B" Stroke="#5746A6" StrokeThickness="1"
                    StrokeShape="RoundRectangle 17" HorizontalOptions="Start" Padding="12,0">
                <HorizontalStackLayout Spacing="7" VerticalOptions="Center">
                    <Label Text=" " TextColor="#A78BFA" FontSize="14" VerticalOptions="Center" />
                    <Label Text="LEARN. COMPETE. LEVEL UP." TextColor="#C4B5FD" FontSize="11"
                           FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
            <Label Text="Ready for your&#10;next challenge?" Margin="0,22,0,0" TextColor="#F8FAFC"
                   FontSize="42" FontAttributes="Bold" LineHeight="1.05" />
            <Label Text="Turn study sessions into victories. Build your decks, face a boss, and master every question."
                   Margin="0,16,0,0" TextColor="#A9B6CF" FontSize="16" LineHeight="1.4" />
            <Grid Margin="0,32,0,0" ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border BackgroundColor="#161F38" Stroke="#2C3A5C" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="14">
                    <VerticalStackLayout Spacing="3">
                        <Label Text="YOUR ARENA" TextColor="#8290AA" FontSize="10" FontAttributes="Bold" />
                        <Label Text="Solo battle" TextColor="#F8FAFC" FontSize="16" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" BackgroundColor="#161F38" Stroke="#2C3A5C" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="14">
                    <VerticalStackLayout Spacing="3">
                        <Label Text="STATUS" TextColor="#8290AA" FontSize="10" FontAttributes="Bold" />
                        <Label Text="Ready to play" TextColor="#5EEAD4" FontSize="16" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </VerticalStackLayout>

        <!-- Actions -->
        <VerticalStackLayout Grid.Row="2" Spacing="12" MaximumWidthRequest="560">
            <Button Text="START A BATTLE   " Clicked="OnPlayClicked" HeightRequest="58"
                    BackgroundColor="#8B5CF6" TextColor="White" FontSize="16" FontAttributes="Bold"
                    CornerRadius="16" />
            <Button Text="LEADERBOARDS" Clicked="OnLeaderboardClicked" HeightRequest="52"
            BackgroundColor="#18213C" TextColor="#5EEAD4" FontSize="14" FontAttributes="Bold"
            BorderColor="#31405F" BorderWidth="1" CornerRadius="14" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="MY DECKS" Clicked="OnDecksClicked" HeightRequest="52"
                        BackgroundColor="#18213C" TextColor="#E2E8F0" FontSize="14" FontAttributes="Bold"
                        BorderColor="#31405F" BorderWidth="1" CornerRadius="14" />
                <Button Grid.Column="1" Text="TUTORIAL" Clicked="OnTutorialClicked" HeightRequest="52"
                        BackgroundColor="#18213C" TextColor="#A78BFA" FontSize="14" FontAttributes="Bold"
                        BorderColor="#31405F" BorderWidth="1" CornerRadius="14" />
            </Grid>
            <Button Text="EXIT" Clicked="OnExitClicked" HeightRequest="52"
            BackgroundColor="#18213C" TextColor="#FDA4AF" FontSize="14" FontAttributes="Bold"
            BorderColor="#533040" BorderWidth="1" CornerRadius="14" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>