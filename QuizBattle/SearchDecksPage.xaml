<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizBattle.SearchDecksPage"
             BackgroundColor="#091121" Title="Global Search">
    <VerticalStackLayout Padding="20" Spacing="15">
        <SearchBar x:Name="DeckSearchBar" Placeholder="Search decks..." TextChanged="OnSearchTextChanged" TextColor="White" />
        <CollectionView x:Name="SearchResultsView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5" Padding="15" BackgroundColor="#17274A" StrokeShape="RoundRectangle 10">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="{Binding Name}" VerticalOptions="Center" TextColor="White" FontAttributes="Bold"/>
                            <Button Grid.Column="1" Text="PREVIEW" Clicked="OnDownloadClicked" CommandParameter="{Binding .}" BackgroundColor="#8B5CF6" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>