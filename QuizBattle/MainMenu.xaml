<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="QuizBattle.MainMenu"
    Title="Quiz Battle">

    <VerticalStackLayout
        VerticalOptions="Center"
        HorizontalOptions="Center"
        Spacing="20">

        <Label
            Text="Quiz Battle"
            FontSize="32"
            HorizontalOptions="Center" />

        <Button
            Text="Play"
            Clicked="PlayClicked" />

    </VerticalStackLayout>

</ContentPage>