<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizBattle.SourceMaterial"
             Title="Source Material &amp; Setup"
             BackgroundColor="#121212">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="15">

                <Label Text="MATCH SETUP" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"/>

                <Label Text="SELECT DECK:" TextColor="White" FontAttributes="Bold"/>
                <Button x:Name="DeckDropdownButton"
                        Text="ACTIVE DECK: NONE ▾"
                        Clicked="ToggleDropdownLayout"
                        BackgroundColor="#1E1E1E"
                        TextColor="White"
                        FontAttributes="Bold"/>

                <ScrollView x:Name="DropdownScrollContainer" IsVisible="False" MaximumHeightRequest="150" BackgroundColor="#2D2D2D">
                    <VerticalStackLayout x:Name="DropdownStackList" Spacing="2" Padding="5"/>
                </ScrollView>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <Button Grid.Column="0" Text="GENERATE WITH AI" Clicked="OpenGenerateDeckModal" BackgroundColor="SeaGreen" TextColor="White"/>
                    <Button Grid.Column="1" Text="IMPORT DECK TEXT" Clicked="OpenImportDeckModal" BackgroundColor="DodgerBlue" TextColor="White"/>
                </Grid>

                <Label Text="SELECT DIFFICULTY:" 
                       TextColor="White" 
                       FontAttributes="Bold" 
                       FontSize="16" 
                       Margin="0,10,0,0"/>

                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="5">
                    <HorizontalStackLayout Grid.Column="0" Spacing="2">
                        <CheckBox x:Name="EasyCheck" CheckedChanged="OnDifficultyChanged" Color="Lime"/>
                        <Label Text="EASY" TextColor="White" VerticalOptions="Center" FontSize="11"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Grid.Column="1" Spacing="2">
                        <CheckBox x:Name="MediumCheck" CheckedChanged="OnDifficultyChanged" Color="Yellow"/>
                        <Label Text="MED" TextColor="White" VerticalOptions="Center" FontSize="11"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Grid.Column="2" Spacing="2">
                        <CheckBox x:Name="HardCheck" CheckedChanged="OnDifficultyChanged" Color="Red"/>
                        <Label Text="HARD" TextColor="White" VerticalOptions="Center" FontSize="11"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Grid.Column="3" Spacing="2">
                        <CheckBox x:Name="ZenCheck" CheckedChanged="OnDifficultyChanged" Color="Cyan"/>
                        <Label Text="ZEN" TextColor="White" VerticalOptions="Center" FontSize="11"/>
                    </HorizontalStackLayout>
                </Grid>

                <Label x:Name="TimerTitleLabel" 
                       Text="Timer (Default: 15s):" 
                       TextColor="White" 
                       Margin="0,10,0,2"/>

                <Entry x:Name="TimerEntry" 
                       Text="15" 
                       Keyboard="Numeric" 
                       TextChanged="OnTimerTextChanged" 
                       TextColor="White" 
                       BackgroundColor="#1E1E1E"/>

            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="1" 
                Text="START BATTLE" 
                Clicked="OnFinalLaunchClicked" 
                BackgroundColor="Crimson" 
                TextColor="White" 
                FontAttributes="Bold" 
                FontSize="18" 
                HeightRequest="55" 
                Margin="20"/>

        <Grid x:Name="SetupPopupOverlay" IsVisible="False" BackgroundColor="#CC000000" Padding="20">
            <Border BackgroundColor="#1E1E1E" Stroke="White" StrokeThickness="1" VerticalOptions="Center" Padding="20">
                <VerticalStackLayout Spacing="10">
                    <VerticalStackLayout x:Name="SetupPopupBody" Spacing="10"/>
                    <Button Text="CANCEL" Clicked="CloseSetupPopup" BackgroundColor="Gray" TextColor="White"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>

</ContentPage>