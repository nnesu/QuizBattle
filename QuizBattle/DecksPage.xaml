<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizBattle.DecksPage"
             Title="Manage Decks"
             BackgroundColor="#121212">

    <Grid>
        <ScrollView x:Name="DecksView" Padding="20">
            <VerticalStackLayout Spacing="15">
                <Label Text="Your Decks" FontSize="24" FontAttributes="Bold" TextColor="White" Margin="0,0,0,10"/>
                <Grid x:Name="DecksGrid" ColumnDefinitions="*,*" ColumnSpacing="15" RowSpacing="15"/>
            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="CardsView" RowDefinitions="Auto, Auto, *, Auto" Padding="20" BackgroundColor="#121212" IsVisible="False">
            <HorizontalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,10">
                <Button Text="← Back" Clicked="CloseCardsView" BackgroundColor="#444"/>
                <Label x:Name="DeckTitleLabel" Text="Deck View" FontSize="22" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,0,0,15">
                <Button Grid.Column="0" Text="Rename Deck" Clicked="OnRenameDeckClicked" BackgroundColor="#F4A261" TextColor="White"/>
                <Button Grid.Column="1" Text="Delete Deck" Clicked="OnDeleteDeckClicked" BackgroundColor="#E63946" TextColor="White"/>
            </Grid>

            <ScrollView Grid.Row="2">
                <Grid x:Name="CardsGrid" ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10"/>
            </ScrollView>

            <Grid Grid.Row="3" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10" Padding="0,15,0,0">
                <Button Grid.Row="0" Grid.Column="0" Text="Generate New Cards" Clicked="OpenGenerateCardsPopup" BackgroundColor="#2A9D8F" TextColor="White"/>
                <Button Grid.Row="0" Grid.Column="1" Text="Create Card" Clicked="OpenCreateCardPopup" BackgroundColor="#457B9D" TextColor="White"/>
                <Button Grid.Row="1" Grid.Column="0" Text="Import Deck" Clicked="OpenImportPopup" BackgroundColor="#A8DADC" TextColor="#1D3557"/>
                <Button Grid.Row="1" Grid.Column="1" Text="Export Deck" Clicked="OpenExportPopup" BackgroundColor="#1D3557" TextColor="White"/>
            </Grid>
        </Grid>

        <Grid x:Name="PopupBackground" BackgroundColor="#B0000000" IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="DismissActivePopup"/>
            </Grid.GestureRecognizers>

            <Border x:Name="PopupContainer" BackgroundColor="#1F1F1F" Stroke="#333" 
                    VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="340" Padding="20">
                <VerticalStackLayout x:Name="PopupContentStack" Spacing="12"/>
            </Border>
        </Grid>
    </Grid>
</ContentPage>