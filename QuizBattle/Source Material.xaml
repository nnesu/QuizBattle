<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="QuizBattle.SourceMaterial"
    Title="Learning Material">

    <VerticalStackLayout
        Padding="20"
        Spacing="20">

        <Label
            Text="Copy-paste your learning material here:"
            FontSize="20" />

        <Editor
            x:Name="MaterialEditor"
            HeightRequest="300"
            AutoSize="TextChanges"
            Placeholder="Paste your notes here..." />

        <Button
            Text="Start Quiz"
            Clicked="StartQuizClicked" />

    </VerticalStackLayout>

</ContentPage>