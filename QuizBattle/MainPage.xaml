<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizBattle.MainPage"
             Title="Quiz Battle"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#091121">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#091121" Offset="0" />
                <GradientStop Color="#101837" Offset="0.55" />
                <GradientStop Color="#0A2133" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <ScrollView>
            <VerticalStackLayout Padding="22,22,22,26" Spacing="0" MaximumWidthRequest="650">
                <!-- Battle header -->
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                    <Button Text="❮" Clicked="OnGiveUpClicked" WidthRequest="44" HeightRequest="44"
                            Padding="0" FontSize="30" FontAttributes="None" BackgroundColor="#17223E"
                            TextColor="#D5DDF2" BorderColor="#304262" BorderWidth="1" CornerRadius="14" />
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,12,0" Spacing="1">
                        <Label Text="QUIZ BATTLE" TextColor="#F8FAFC" FontSize="16" FontAttributes="Bold" />
                        <Label Text="BOSS ENCOUNTER" TextColor="#8EA0C0" FontSize="10" FontAttributes="Bold" />
                    </VerticalStackLayout>
                    <Border Grid.Column="2" BackgroundColor="#202044" Stroke="#4C438C" StrokeThickness="1"
                            StrokeShape="RoundRectangle 14" Padding="11,7">
                        <Label x:Name="TimeLabel" Text="TIME: --" TextColor="#DDD6FE" FontSize="13"
                               FontAttributes="Bold" VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- Combat HUD with Animated Boss -->
                <Border Margin="0,24,0,0" BackgroundColor="#121D37" Stroke="#2A3C60" StrokeThickness="1"
                        StrokeShape="RoundRectangle 22" Padding="18">
                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="10">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="3">
                            <Label Text="CURRENT BOSS" TextColor="#8291AF" FontSize="10" FontAttributes="Bold" />
                            <Label x:Name="BossLabel" Text="BOSS HP: --" TextColor="#F8FAFC" FontSize="22" FontAttributes="Bold" />
                        </VerticalStackLayout>
                        <Border
                            Grid.Row="0"
                            Grid.Column="1"
                            WidthRequest="140"
                            HeightRequest="140"
                            BackgroundColor="#31265C"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20">
                            <Grid>
                                <Image
                                    x:Name="BossImage"
                                    Source="pengu_idle.png"
                                    Aspect="AspectFit"/>
                                <Label
                                    x:Name="DamageLabel"
                                    IsVisible="False"
                                    FontSize="32"
                                    FontAttributes="Bold"
                                    TextColor="Red"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                        <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" Color="#293C5D" />
                        <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="YOUR LIVES" TextColor="#8291AF" FontSize="10" FontAttributes="Bold" VerticalOptions="Center" />
                            <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" HorizontalOptions="End" Spacing="4">
                                <Label x:Name="LivesLabel" Text="LIVES: --" TextColor="#FDA4AF" FontSize="15" FontAttributes="Bold" />
                                <HorizontalStackLayout x:Name="LivesLayout" IsVisible="False" Spacing="4" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Question Header -->
                <VerticalStackLayout Margin="0,28,0,0" Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="CardsCountLabel" Text="Cards Left: --/--" TextColor="#5EEAD4" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                        <Label x:Name="MasteryLabel" Grid.Column="1" Text="" TextColor="#5EEAD4" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>
                    <Border BackgroundColor="#F4F7FF" StrokeThickness="0" StrokeShape="RoundRectangle 22" Padding="22">
                        <Label x:Name="QuestionLabel" Text="Preparing your challenge " TextColor="#14203A"
                               FontSize="22" FontAttributes="Bold" LineHeight="1.3" />
                    </Border>
                </VerticalStackLayout>

                <!-- Answer area -->
                <VerticalStackLayout Margin="0,20,0,0" Spacing="10">
                    <Label Text="YOUR ANSWER" TextColor="#8EA0C0" FontSize="11" FontAttributes="Bold" />
                    <Border BackgroundColor="#15213C" Stroke="#304262" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="4,0">
                        <Entry x:Name="AnswerEntry" Placeholder="Type your answer here" TextColor="#F8FAFC"
                               PlaceholderColor="#7889A8" BackgroundColor="Transparent" FontSize="16" />
                    </Border>
                    <VerticalStackLayout x:Name="MultipleChoiceLayout" IsVisible="False" Spacing="10">
                        <Button x:Name="OptionButton1" Clicked="OptionClicked" BackgroundColor="#1A2644" TextColor="#E7EEFC"
                                BorderColor="#344867" BorderWidth="1" FontAttributes="Bold" HorizontalOptions="Fill" CornerRadius="16" />
                        <Button x:Name="OptionButton2" Clicked="OptionClicked" BackgroundColor="#1A2644" TextColor="#E7EEFC"
                                BorderColor="#344867" BorderWidth="1" FontAttributes="Bold" HorizontalOptions="Fill" CornerRadius="16" />
                        <Button x:Name="OptionButton3" Clicked="OptionClicked" BackgroundColor="#1A2644" TextColor="#E7EEFC"
                                BorderColor="#344867" BorderWidth="1" FontAttributes="Bold" HorizontalOptions="Fill" CornerRadius="16" />
                        <Button x:Name="OptionButton4" Clicked="OptionClicked" BackgroundColor="#1A2644" TextColor="#E7EEFC"
                                BorderColor="#344867" BorderWidth="1" FontAttributes="Bold" HorizontalOptions="Fill" CornerRadius="16" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Label x:Name="ResultLabel" Margin="0,12,0,0" FontSize="14" FontAttributes="Bold"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                <Button Text="LOCK IN ANSWER   " Clicked="SubmitAnswer" Margin="0,12,0,0" HeightRequest="58"
                        BackgroundColor="#14B8A6" TextColor="#052D2A" FontSize="16" FontAttributes="Bold" CornerRadius="16" />
                <Label Text="Choose wisely. Every answer changes the battle." Margin="0,14,0,0" TextColor="#71819F"
                       FontSize="12" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>