<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizBattle.DecksPage"
             Title="My Decks"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#091121">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#091121" Offset="0" />
                <GradientStop Color="#101837" Offset="0.58" />
                <GradientStop Color="#0A2133" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <!-- Deck collection -->
        <ScrollView x:Name="DecksView">
            <VerticalStackLayout Padding="22,22,22,28" Spacing="0" MaximumWidthRequest="700">
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                    <Button Text="‹" Clicked="OnBackClicked" WidthRequest="44" HeightRequest="44" Padding="0"
                            FontSize="30" FontAttributes="None" BackgroundColor="#17223E" TextColor="#D5DDF2"
                            BorderColor="#304262" BorderWidth="1" CornerRadius="14" />
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" Spacing="1">
                        <Label Text="MY DECKS" TextColor="#F8FAFC" FontSize="20" FontAttributes="Bold" />
                        <Label Text="BUILD YOUR KNOWLEDGE ARSENAL" TextColor="#8291AF" FontSize="10" FontAttributes="Bold" />
                    </VerticalStackLayout>
                    <Border Grid.Column="2" BackgroundColor="#1E2444" Stroke="#414170" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="11,7">
                        <Label Text="COLLECTION" TextColor="#C4B5FD" FontSize="10" FontAttributes="Bold" />
                    </Border>
                </Grid>
                <Border Margin="0,26,0,0" BackgroundColor="#121D37" Stroke="#2A3C60" StrokeThickness="1" StrokeShape="RoundRectangle 22" Padding="20">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="PICK A DECK TO TRAIN" TextColor="#8EA0C0" FontSize="11" FontAttributes="Bold" />
                        <Label Text="Your study decks" TextColor="#F8FAFC" FontSize="26" FontAttributes="Bold" />
                        <Label Text="Open a deck to create, edit, import, or generate question cards." TextColor="#A9B6CF" FontSize="14" LineHeight="1.35" />
                    </VerticalStackLayout>
                </Border>
                <Grid Margin="0,26,0,12" ColumnDefinitions="*,Auto">
                    <Label Text="ALL DECKS" TextColor="#A9B6CF" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="TAP TO OPEN" TextColor="#5EEAD4" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                </Grid>
                <Grid x:Name="DecksGrid" ColumnDefinitions="*,*" ColumnSpacing="12" RowSpacing="12" />
            </VerticalStackLayout>
        </ScrollView>
        <!-- Active deck workspace -->
        <Grid x:Name="CardsView" IsVisible="False" RowDefinitions="Auto,Auto,*,Auto" Padding="22,22,22,26">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Button Text="‹" Clicked="CloseCardsView" WidthRequest="44" HeightRequest="44" Padding="0"
                        FontSize="30" FontAttributes="None" BackgroundColor="#17223E" TextColor="#D5DDF2"
                        BorderColor="#304262" BorderWidth="1" CornerRadius="14" />
                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="DECK WORKSPACE" TextColor="#8291AF" FontSize="10" FontAttributes="Bold" />
                    <Label x:Name="DeckTitleLabel" Text="DECK" TextColor="#F8FAFC" FontSize="22" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                </VerticalStackLayout>
            </Grid>
            <Grid Grid.Row="1" Margin="0,22,0,18" ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="RENAME" Clicked="OnRenameDeckClicked" HeightRequest="48" BackgroundColor="#1A2644" TextColor="#DCE7FA"
                        BorderColor="#344867" BorderWidth="1" FontAttributes="Bold" CornerRadius="14" />
                <Button Grid.Column="1" Text="DELETE DECK" Clicked="OnDeleteDeckClicked" HeightRequest="48" BackgroundColor="#301D31" TextColor="#FDA4AF"
                        BorderColor="#67374B" BorderWidth="1" FontAttributes="Bold" CornerRadius="14" />
            </Grid>
            <ScrollView Grid.Row="2">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="QUESTION CARDS" TextColor="#A9B6CF" FontSize="11" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="TAP TO EDIT" TextColor="#5EEAD4" FontSize="11" FontAttributes="Bold" />
                    </Grid>
                    <Grid x:Name="CardsGrid" ColumnDefinitions="*,*" ColumnSpacing="12" RowSpacing="12" />
                </VerticalStackLayout>
            </ScrollView>
            <Grid Grid.Row="3" Margin="0,18,0,0" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10">
                <Button Grid.Row="0" Grid.Column="0" Text="GENERATE CARDS" Clicked="OpenGenerateCardsPopup" HeightRequest="50"
                        BackgroundColor="#14B8A6" TextColor="#052D2A" FontAttributes="Bold" CornerRadius="14" />
                <Button Grid.Row="0" Grid.Column="1" Text="CREATE CARD" Clicked="OpenCreateCardPopup" HeightRequest="50"
                        BackgroundColor="#8B5CF6" TextColor="White" FontAttributes="Bold" CornerRadius="14" />
                <Button Grid.Row="1" Grid.Column="0" Text="IMPORT" Clicked="OpenImportPopup" HeightRequest="46"
                        BackgroundColor="#1A2644" TextColor="#DCE7FA" BorderColor="#344867" BorderWidth="1" FontAttributes="Bold" CornerRadius="14" />
                <Button Grid.Row="1" Grid.Column="1" Text="EXPORT" Clicked="OpenExportPopup" HeightRequest="46"
                        BackgroundColor="#1A2644" TextColor="#DCE7FA" BorderColor="#344867" BorderWidth="1" FontAttributes="Bold" CornerRadius="14" />
            </Grid>
        </Grid>
        <!-- Shared modal backdrop -->
        <Grid x:Name="PopupBackground" BackgroundColor="#C9000718" IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="DismissActivePopup" />
            </Grid.GestureRecognizers>
            <Border x:Name="PopupContainer" BackgroundColor="#121D37" Stroke="#344867" StrokeThickness="1"
                    VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="340" Padding="20" StrokeShape="RoundRectangle 20">
                <VerticalStackLayout x:Name="PopupContentStack" Spacing="12" />
            </Border>
        </Grid>
    </Grid>
</ContentPage>