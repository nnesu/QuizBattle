<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizBattle.DecksPage"
             Title="My Decks"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#091121">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#091121" Offset="0" />
                <GradientStop Color="#101837" Offset="0.55" />
                <GradientStop Color="#0A2133" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <VerticalStackLayout Padding="22,22,22,26" Spacing="0">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                <Button Text=" " Clicked="OnBackClicked" WidthRequest="44" HeightRequest="44"
                        Padding="0" FontSize="30" BackgroundColor="#17223E"
                        TextColor="#D5DDF2" BorderColor="#304262" BorderWidth="1" CornerRadius="14" />
                <VerticalStackLayout Grid.Column="1" Margin="12,0,12,0" Spacing="1">
                    <Label Text="MY DECKS" TextColor="#F8FAFC" FontSize="16" FontAttributes="Bold" />
                    <Label Text="LOCAL ARSENAL" TextColor="#8EA0C0" FontSize="10" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,24,0,20">
                <Button Grid.Column="0" Text="+ CREATE DECK" Clicked="OnCreateDeckClicked" HeightRequest="52"
                        BackgroundColor="#8B5CF6" TextColor="White" FontSize="12" FontAttributes="Bold"
                        CornerRadius="14" />

                <Button Grid.Column="1" Text="SEARCH GLOBAL" Clicked="OnSearchGlobalClicked" HeightRequest="52"
                        BackgroundColor="#18213C" TextColor="#5EEAD4" FontSize="12" FontAttributes="Bold"
                        BorderColor="#31405F" BorderWidth="1" CornerRadius="14" />
            </Grid>

            <BoxView HeightRequest="1" Color="#293C5D" Margin="0,0,0,20"/>

            <CollectionView x:Name="DecksCollectionView" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No decks found. Create one or search globally!" 
                           TextColor="#8291AF" HorizontalOptions="Center" Margin="0,40,0,0" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" BackgroundColor="#121D37" Stroke="#2A3C60" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="16">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" TextColor="#F8FAFC" FontSize="16" FontAttributes="Bold" />
                                </VerticalStackLayout>

                                <HorizontalStackLayout Grid.Column="1" Spacing="8">
                                    <Button Text="EDIT" Clicked="OnEditDeckClicked" CommandParameter="{Binding .}" 
                                            BackgroundColor="#1E2A4F" TextColor="#A9B6CF" FontSize="10" FontAttributes="Bold" 
                                            HeightRequest="36" CornerRadius="8" Padding="12,0"/>
                                    <Button Text="DEL" Clicked="OnDeleteDeckClicked" CommandParameter="{Binding .}" 
                                            BackgroundColor="#3A1C28" TextColor="#FDA4AF" FontSize="10" FontAttributes="Bold" 
                                            HeightRequest="36" CornerRadius="8" Padding="12,0"/>
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </Grid>
</ContentPage>